{
  "rewrites": [
    { "source": "/admin/:path*", "destination": "/admin/index.html" },
    { "source": "/uploads/:path*", "destination": "/static/uploads/:path*" }
  ],
  "redirects": [
    { "source": "/admin", "destination": "/admin/", "permanent": true }
  ],
  "functions": {
    "api/auth.js": { "maxDuration": 10 }
  }
}